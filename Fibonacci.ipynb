      "8\n"
     ]
    }
   ],
   "source": [
    "print(fib(6))  # 8"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "b3de25b5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# iterative"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "6fde95f7",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fib(n):\n",
    "    a, b = 0, 1\n",
    "    \n",
    "    for _ in range(n):\n",
    "        a, b = b, a + b\n",
    "    \n",
    "    return a\n"
   ]
  },
  {
