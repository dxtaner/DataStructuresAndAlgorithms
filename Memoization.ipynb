   "source": [
    "def fib(n, memo={}):\n",
    "    if n in memo:\n",
    "        print(f\"cache hit: fib({n}) = {memo[n]}\")\n",
    "        return memo[n]\n",
    "    \n",
    "    print(f\"hesaplanıyor: fib({n})\")\n",
    "    \n",
    "    if n <= 1:\n",
    "        return n\n",
    "    \n",
    "    memo[n] = fib(n-1, memo) + fib(n-2, memo)\n",
    "    return memo[n]\n"
   ]
  },
